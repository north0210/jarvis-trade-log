# --- J-Quants API V2（株価・財務の自動取得）---
# ダッシュボード [設定 » APIキー] で発行した API キー。
# サーバ側でのみ参照され、設定画面（localStorage）より優先される。
# 実キーは .env.local に記載し、コミットしないこと（.gitignore 済み）。
JQUANTS_API_KEY=YOUR_JQUANTS_V2_API_KEY

# --- V1 認証（@deprecated：2025-12-22 以降の登録者は利用不可）---
# 既存 V1 ユーザーのみ。V2 では不要。
# JQUANTS_EMAIL=you@example.com
# JQUANTS_PASSWORD=YOUR_PASSWORD

# --- Supabase（レガシー・未使用）---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
